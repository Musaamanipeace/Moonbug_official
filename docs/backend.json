
{
  "entities": {
    "Profile": {
      "title": "Student Profile",
      "description": "Student identification and rewards tracking.",
      "type": "object",
      "properties": {
        "nickname": { "type": "string" },
        "schoolName": { "type": "string" },
        "studentId": { "type": "string" },
        "email": { "type": "string" },
        "rewardsBalance": { "type": "number", "description": "Currency earned via surveys" },
        "hasPaid": { "type": "boolean", "description": "Unlock nickname changes" }
      },
      "required": ["nickname", "studentId"]
    },
    "Scope": {
      "title": "Scope",
      "description": "A 'father class' container for grouping notes and tasks.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "color": { "type": "string" },
        "icon": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "deadline": { "type": "string", "format": "date-time" },
        "reminderAt": { "type": "string", "format": "date-time" },
        "tasks": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "details": { "type": "string" },
              "completed": { "type": "boolean" }
            }
          }
        }
      },
      "required": ["name"]
    },
    "Note": {
      "title": "Note",
      "description": "Specific productivity units.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "scopeId": { "type": "string" },
        "type": { "type": "string", "enum": ["note", "list", "todo", "idea", "event", "reminder", "deadline"] },
        "isCompleted": { "type": "boolean" },
        "voiceDataUri": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["content", "scopeId"]
    },
    "Survey": {
      "title": "Survey",
      "description": "Institutional data collection forms.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "reward": { "type": "number" },
        "questions": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["available", "completed"] }
      }
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/users/{userId}/profile": {
      "schema": "Profile",
      "description": "Student identity"
    },
    "/users/{userId}/scopes/{scopeId}": {
      "schema": "Scope",
      "description": "Category containers"
    },
    "/users/{userId}/notes/{noteId}": {
      "schema": "Note",
      "description": "Productivity entries"
    },
    "/surveys/{surveyId}": {
      "schema": "Survey",
      "description": "Global learning surveys"
    }
  }
}
